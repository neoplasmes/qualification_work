{
    "name": "client",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev": "pnpm typecheck && tsx --env-file=.env server/server.ts",
        "build:client": "vite build",
        "build:server": "tsup && cp server/renderError.html dist/ && vite build --ssr src/entry.server.tsx --outDir dist/server",
        "build": "pnpm build:server && pnpm build:client",
        "preview": "pnpm build && pnpm start",
        "typecheck": "tsc --noEmit",
        "start": "NODE_ENV=production node --env-file=.env dist/server.js",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "lint:ts": "oxlint -c oxlint.config.ts src/",
        "lint:css": "stylelint \"src/**/*.scss\"",
        "lint": "pnpm lint:ts && pnpm lint:css",
        "lint:fix:ts": "oxlint -c oxlint.config.ts --fix src/",
        "lint:fix:css": "stylelint \"src/**/*.scss\" --fix",
        "lint:fix": "pnpm lint:fix:ts && pnpm lint:fix:css"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "files": [
        "dist"
    ],
    "dependencies": {
        "@glideapps/glide-data-grid": "^6.0.3",
        "@reduxjs/toolkit": "^2.11.2",
        "@visx/axis": "^3.12.0",
        "@visx/curve": "^3.12.0",
        "@visx/event": "^3.12.0",
        "@visx/group": "^3.12.0",
        "@visx/heatmap": "3.12.0",
        "@visx/responsive": "^3.12.0",
        "@visx/scale": "^3.12.0",
        "@visx/shape": "^3.12.0",
        "@visx/tooltip": "^3.12.0",
        "@visx/visx": "^3.12.0",
        "lucide-react": "^1.14.0",
        "motion": "^12.38.0",
        "primitive-server": "workspace:*",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-redux": "^9.2.0",
        "react-router": "^7.13.2",
        "turbo-stream": "^3.2.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@qualification-work/eslint-plugin-fsd": "workspace:*",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.4.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "exceljs": "^4.4.0",
        "jsdom": "^28.1.0",
        "sass": "^1.97.3",
        "stylelint": "^17.6.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "vite": "^8.0.10"
    }
}
