NODE_ENV=development

DATABASE_URL=postgres://admin:local_password@localhost:5432/qualification

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=local_password

DATA_SERVICE_PORT=3003
CLIENT_ORIGIN=http://localhost:3000

AUTH_JWKS_URL=http://localhost:8080/gateway/.well-known/jwks.json
AUTH_JWT_ISSUER=qualification-auth
AUTH_JWT_AUDIENCE=internal
DEV_INTERNAL_IDENTITY={"userId":"dev-user","orgs":[{"id":"dev-org","role":"owner"}]}

MERGE_TMP_DIR=/tmp/datasets
MERGE_SESSION_TTL_SECONDS=1800
MERGE_MAX_FILE_BYTES=524288000
MERGE_MAX_ROWS_IN_MEMORY=100000
MERGE_MAX_EXISTING_ROWS=1000000
MERGE_CLEANUP_INTERVAL_MS=300000
