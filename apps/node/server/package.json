{
    "name": "server",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev": "pnpm db:up && tsx watch --env-file=.env src/index.ts",
        "build": "tsup src/index.ts --format esm --target esnext --out-dir dist",
        "start": "node dist/index.mjs",
        "typecheck": "tsc --noEmit",
        "db:up": "docker compose --env-file .env -f ../../../docker-compose.dev.yaml up postgres redis redis-insight -d --wait",
        "db:down": "docker compose -f ../../../docker-compose.dev.yaml down",
        "db:test:up": "docker compose --env-file .env.test -f ../../../docker-compose.test.yaml up -d --wait --renew-anon-volumes postgres redis",
        "db:test:down": "docker compose -f ../../../docker-compose.test.yaml down -v",
        "lint": "oxlint -c oxlint.config.ts src/",
        "lint:fix": "oxlint -c oxlint.config.ts --fix src/",
        "test": "pnpm db:test:up && pnpm dotenv -e .env.test -- vitest run"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "files": [
        "dist"
    ],
    "dependencies": {
        "@fastify/busboy": "^3.2.0",
        "@qualification-work/types": "workspace:*",
        "argon2": "^0.44.0",
        "csv-parse": "^6.2.1",
        "exceljs": "^4.4.0",
        "fast-json-stringify": "^6.3.0",
        "pg": "^8.20.0",
        "primitive-server": "workspace:*",
        "redis": "^5.11.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/pg": "^8.18.0",
        "dotenv": "^17.3.1",
        "dotenv-cli": "^11.0.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0"
    }
}
