{
    "name": "server",
    "version": "1.0.0",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev": "pnpm dotenv -e .env -- tsx watch src/index.ts",
        "build": "tsup src/index.ts --format esm --target esnext --out-dir dist",
        "start": "pnpm dotenv -e .env -- node dist/index.js",
        "lint": "oxlint -c oxlint.config.ts src/",
        "lint:fix": "oxlint -c oxlint.config.ts --fix src/",
        "typecheck": "tsc --noEmit",
        "test": "pnpm dotenv -e .env.test -- vitest run"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "files": [
        "dist"
    ],
    "dependencies": {
        "@qualification-work/types": "workspace:*",
        "fast-json-stringify": "^6.3.0",
        "pg": "catalog:postgres",
        "primitive-server": "workspace:*",
        "redis": "catalog:backend",
        "zod": "catalog:backend"
    },
    "devDependencies": {
        "@qualification-work/microservice-config": "workspace:*",
        "@qualification-work/types": "workspace:*",
        "@types/pg": "catalog:postgres",
        "dotenv": "catalog:devtools",
        "dotenv-cli": "catalog:devtools",
        "tsup": "catalog:devtools",
        "tsx": "catalog:devtools"
    }
}
