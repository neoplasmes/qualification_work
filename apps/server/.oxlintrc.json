{
    "extends": ["../../.oxlintrc.json"],
    "rules": {
        "no-restricted-imports": [
            "error",
            {
                "patterns": [
                    {
                        "group": ["**/index", "**/index.ts"]
                    },
                    {
                        "regex": "^@/(?!core/ports/)\\w+/\\w+/.+"
                    }
                ]
            }
        ]
    }
}
