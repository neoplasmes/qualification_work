{
    "name": "server",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev": "pnpm db:up && tsx watch --env-file=../../.env src/index.ts",
        "build": "tsup src/index.ts --format esm --target esnext --out-dir dist",
        "start": "node dist/index.mjs",
        "typecheck": "tsc --noEmit",
        "db:up": "docker compose -f ../../docker-compose.dev.yml up postgres redis redis-insight -d",
        "db:down": "docker compose -f ../../docker-compose.dev.yml down",
        "lint": "oxlint -c oxlint.config.ts src/",
        "lint:fix": "oxlint -c oxlint.config.ts --fix src/",
        "test": "pnpm dotenv -e ../../.env -- vitest run"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "packageManager": "pnpm@10.32.0",
    "dependencies": {
        "@fastify/busboy": "^3.2.0",
        "@qualification-work/types": "workspace:*",
        "argon2": "^0.44.0",
        "csv-parse": "^6.2.1",
        "exceljs": "^4.4.0",
        "fast-json-stringify": "^6.3.0",
        "pg": "^8.20.0",
        "primitive-server": "workspace:*",
        "redis": "^5.11.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.4.0",
        "@types/pg": "^8.18.0",
        "dotenv": "^17.3.1",
        "dotenv-cli": "^11.0.0",
        "oxlint": "^1.58.0",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    }
}
