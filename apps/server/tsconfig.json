{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2020"],
        "module": "ESNext",
        // bundler - tsup
        "moduleResolution": "bundler",
        "outDir": "dist",
        "rootDir": "src",
        "noEmit": false,
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"]
        }
    },
    "include": ["src/**/*"]
}
