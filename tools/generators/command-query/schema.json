{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "id": "cqrs",
    "title": "CQRS Generator",
    "description": "Generate a Command or Query",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "description": "Command or Query",
            "enum": ["command", "query"],
            "x-prompt": {
                "message": "what do you want to create?",
                "type": "list",
                "items": [
                    {
                        "value": "command",
                        "label": "Command"
                    },
                    {
                        "value": "query",
                        "label": "Query"
                    }
                ]
            }
        },
        "name": {
            "type": "string",
            "description": "Name, for example register or getData",
            "x-prompt": "Name, for example register or getData:"
        }
    },
    "required": ["kind", "name"]
}
