{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "id": "repository-service",
    "title": "Repository / Service Generator",
    "description": "Generate port interface + implementation class for a repository or service",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "description": "repository or service",
            "enum": ["repository", "service"],
            "x-prompt": {
                "message": "What do you want to create?",
                "type": "list",
                "items": [
                    {
                        "value": "repository",
                        "label": "Repository"
                    },
                    {
                        "value": "service",
                        "label": "Service"
                    }
                ]
            }
        },
        "name": {
            "type": "string",
            "description": "Name in camelCase",
            "x-prompt": "Name in camelCase"
        }
    },
    "required": ["kind", "name"]
}
