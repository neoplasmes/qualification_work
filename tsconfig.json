{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2023"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,

        // убрал потому что занудство
        "noUncheckedIndexedAccess": false,

        "noImplicitOverride": true
    }
}
